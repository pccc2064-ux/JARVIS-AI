# Copy this file to ".env" and fill in the keys for whichever providers you use.
# Never commit your real .env file to version control.

OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
GOOGLE_API_KEY=AIza...

# Optional overrides
OPENAI_MODEL=gpt-4o
ANTHROPIC_MODEL=claude-sonnet-4-6
GEMINI_MODEL=gemini-2.0-flash

# TTS_ENGINE: pyttsx3 (offline) or gtts (needs internet)
TTS_ENGINE=pyttsx3

# STT_ENGINE: google (free web API) or whisper (OpenAI API, needs OPENAI_API_KEY)
STT_ENGINE=google
